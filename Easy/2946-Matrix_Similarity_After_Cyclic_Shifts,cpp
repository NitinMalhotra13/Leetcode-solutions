class Solution {
public:
    bool areSimilar(vector<vector<int>>& g, int k) {
        int m = g.size(), n = g[0].size();
        k %= n;

        for (int i = 0; i < m; i++){
            for (int j = 0; j < n; j++){
                if (g[i][j] != g[i][(i % 2 ? j - k + n : j + k) % n]){
                    return false;
                }
            }
        }
        return true;
    }
};
